# 1. Χρησιμοποίησε την επίσημη εικόνα του Node.js ως βάση
FROM node:18

# 2. Όρισε τον φάκελο μέσα στο container όπου θα ζει η εφαρμογή
WORKDIR /usr/src/app

# 3. Αντίγραψε τα αρχεία των εξαρτήσεων (package.json)
COPY package*.json ./

# 4. Εγκατάστησε τις βιβλιοθήκες (στην περίπτωσή μας, το express)
RUN npm install

# 5. Αντίγραψε όλο τον υπόλοιπο κώδικα (το index.js) μέσα στο container
COPY . .

# 6. Άνοιξε την πόρτα 3000 για να μπορεί να επικοινωνήσει η εφαρμογή με τον έξω κόσμο
EXPOSE 3000

# 7. Η εντολή για να ξεκινήσει η εφαρμογή
CMD ["npm", "start"]
